# إعدادات السيرفر
PORT=5000
NODE_ENV=development

# إعدادات قاعدة البيانات MongoDB
# ضع رابط MongoDB الخاص بك هنا
MONGODB_URI=mongodb://localhost:27017/hammurabi
# أو استخدم MongoDB Atlas:
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/hammurabi?retryWrites=true&w=majority

# إعدادات JWT للمصادقة
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRE=30d

# إعدادات Anthropic Claude API
# ضع API Key الخاص بك هنا
ANTHROPIC_API_KEY=your-anthropic-api-key-here
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# إعدادات التطبيق
ADMIN_DEFAULT_USERNAME=admin
ADMIN_DEFAULT_PASSWORD=admin123
ADMIN_DEFAULT_EMAIL=admin@hammurabi.com

# إعدادات الملفات المرفوعة
MAX_FILE_SIZE=50MB
UPLOAD_PATH=./uploads

# URL الخاص بالـ Frontend
FRONTEND_URL=http://localhost:3000
